# ── JobHunter Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.

# Google Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (send /start to @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Sheets — the ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_SHEET_ID/edit
SHEET_ID=your_google_sheet_id_here

# (Optional) Custom paths to credential files
# SHEETS_CREDENTIALS_PATH=./sheets_credentials.json
# GMAIL_CREDENTIALS_PATH=./gmail_credentials.json

# Wellfound login (for auto-apply in Phase 6)
# WELLFOUND_EMAIL=your_wellfound_email
# WELLFOUND_PASSWORD=your_wellfound_password
